<Window x:Class="DWGToNWCConverter.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="DWG to NWC Converter"
        Height="1100"
        Width="1200"
        MinHeight="900"
        MinWidth="1200"
        MaxWidth="1200"
        ResizeMode="CanResizeWithGrip"
        WindowStartupLocation="Manual"
        Background="#1f1f1e">
    <Window.Resources>
        <SolidColorBrush x:Key="WindowBrush" Color="#252523" />
        <SolidColorBrush x:Key="PanelBrush" Color="#2c2c2a" />
        <SolidColorBrush x:Key="PanelAltBrush" Color="#252523" />
        <SolidColorBrush x:Key="BorderBrush" Color="#3d3d39" />
        <SolidColorBrush x:Key="AccentBrush" Color="#d97757" />
        <SolidColorBrush x:Key="AccentHoverBrush" Color="#ff9666" />
        <SolidColorBrush x:Key="AccentDimBrush" Color="#47161a" />
        <SolidColorBrush x:Key="SecondaryHoverBrush" Color="#51514f" />
        <SolidColorBrush x:Key="DisabledButtonBrush" Color="#3a2628" />
        <SolidColorBrush x:Key="TextBrush" Color="#c2c0b6" />
        <SolidColorBrush x:Key="MutedTextBrush" Color="#a9a79d" />
        <SolidColorBrush x:Key="WarnBrush" Color="#e81123" />
        <SolidColorBrush x:Key="DangerBrush" Color="#e81123" />
        <SolidColorBrush x:Key="ReadyBrush" Color="#76c893" />

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="FontFamily" Value="Segoe UI Semibold" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Background" Value="#252523" />
            <Setter Property="BorderBrush" Value="{StaticResource PanelBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="FontSize" Value="14" />
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Background" Value="#252523" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="MinHeight" Value="35" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="OuterBorder"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="36" />
                                    </Grid.ColumnDefinitions>

                                    <ContentPresenter Margin="{TemplateBinding Padding}"
                                                      VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                                      HorizontalAlignment="Left"
                                                      Content="{TemplateBinding SelectionBoxItem}"
                                                      ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                      ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                                      IsHitTestVisible="False" />

                                    <ToggleButton Grid.Column="1"
                                                  Focusable="False"
                                                  Background="Transparent"
                                                  BorderThickness="0"
                                                  ClickMode="Press"
                                                  IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}">
                                        <Path x:Name="DropDownArrow"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Fill="{TemplateBinding Foreground}"
                                              Data="M 0 0 L 4 4 L 8 0 Z" />
                                    </ToggleButton>
                                </Grid>
                            </Border>

                            <Popup x:Name="PART_Popup"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   Placement="Bottom"
                                   PopupAnimation="Slide">
                                <Border Margin="0,2,0,0"
                                        MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                        MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                        Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}">
                                    <ScrollViewer CanContentScroll="True"
                                                  SnapsToDevicePixels="True">
                                        <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained" />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="HasItems" Value="False">
                                <Setter TargetName="PART_Popup" Property="MinHeight" Value="24" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="DropDownArrow" Property="Fill" Value="{StaticResource AccentHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsDropDownOpen" Value="True">
                                <Setter TargetName="DropDownArrow" Property="Fill" Value="{StaticResource AccentHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
                                <Setter TargetName="OuterBorder" Property="Opacity" Value="0.7" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Background" Value="#252523" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="ItemBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{StaticResource PanelAltBrush}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{StaticResource PanelBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <BulletDecorator Background="Transparent">
                            <BulletDecorator.Bullet>
                                <Border x:Name="CheckboxBorder"
                                        Width="32"
                                        Height="32"
                                        Margin="0,0,8,0"
                                        Background="{StaticResource WindowBrush}"
                                        BorderBrush="Transparent"
                                        BorderThickness="1"
                                        CornerRadius="4">
                                    <Path x:Name="CheckboxTick"
                                          Width="10"
                                          Height="8"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Data="M 0 4 L 3 7 L 10 0"
                                          Stroke="{StaticResource AccentBrush}"
                                          StrokeThickness="2.2"
                                          StrokeStartLineCap="Round"
                                          StrokeEndLineCap="Round"
                                          StrokeLineJoin="Round"
                                          Visibility="Collapsed" />
                                </Border>
                            </BulletDecorator.Bullet>
                            <ContentPresenter VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </BulletDecorator>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="CheckboxTick" Property="Visibility" Value="Visible" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
                                <Setter TargetName="CheckboxBorder" Property="Opacity" Value="0.7" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AutomationToggleStyle" TargetType="ToggleButton">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Background" Value="{StaticResource PanelAltBrush}" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Width" Value="34" />
            <Setter Property="Height" Value="34" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="ToggleBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <Path x:Name="Arrow"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  Fill="{StaticResource TextBrush}"
                                  Data="M 0 0 L 6 5 L 0 10 Z" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ToggleBorder" Property="Background" Value="{StaticResource SecondaryHoverBrush}" />
                                <Setter TargetName="ToggleBorder" Property="BorderBrush" Value="{StaticResource SecondaryHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Arrow" Property="RenderTransform">
                                    <Setter.Value>
                                        <RotateTransform Angle="180" CenterX="3" CenterY="5" />
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AutomationPanelExpanderStyle" TargetType="Expander">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Background" Value="{StaticResource PanelBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource PanelBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Expander">
                        <Border x:Name="PanelBorder"
                                Padding="22"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="22"
                                Width="420">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <TextBlock FontSize="22"
                                               FontFamily="Bahnschrift SemiBold"
                                               Text="{TemplateBinding Header}" />

                                    <ToggleButton x:Name="ExpanderToggle"
                                                  Grid.Column="1"
                                                  Style="{StaticResource AutomationToggleStyle}"
                                                  IsChecked="{Binding IsExpanded, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                                  FocusVisualStyle="{x:Null}" />
                                </Grid>

                                <Border x:Name="ExpanderContent"
                                        Margin="0,6,0,0"
                                        Background="Transparent"
                                        Visibility="Visible">
                                    <ContentPresenter />
                                </Border>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsExpanded" Value="False">
                                <Setter TargetName="ExpanderContent" Property="Visibility" Value="Collapsed" />
                                <Setter TargetName="PanelBorder" Property="Width" Value="220" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource PanelBrush}" />
            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="16,10" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontFamily" Value="Segoe UI Semibold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Margin" Value="0,0,10,0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.92" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.8" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource AccentHoverBrush}" />
                    <Setter Property="BorderBrush" Value="{StaticResource AccentHoverBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Background" Value="{StaticResource PanelAltBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource SecondaryHoverBrush}" />
                    <Setter Property="BorderBrush" Value="{StaticResource SecondaryHoverBrush}" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="{StaticResource DisabledButtonBrush}" />
                    <Setter Property="BorderBrush" Value="Transparent" />
                    <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DangerButtonStyle" TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
            <Setter Property="Foreground" Value="#f3d7d8" />
            <Setter Property="Background" Value="{StaticResource AccentDimBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource DangerBrush}" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource DangerBrush}" />
                    <Setter Property="BorderBrush" Value="{StaticResource DangerBrush}" />
                    <Setter Property="Foreground" Value="White" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="ListBox">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Background" Value="#252523" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="6" />
            <Setter Property="FontFamily" Value="Consolas" />
            <Setter Property="FontSize" Value="13" />
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource WindowBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Margin="24,22,24,18"
                Padding="24"
                Background="{StaticResource PanelBrush}"
                CornerRadius="24"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock FontSize="30" FontFamily="Bahnschrift SemiBold" Text="DWG to NWC Converter" />
                    <TextBlock Margin="0,8,0,0"
                               Foreground="{StaticResource MutedTextBrush}"
                               FontSize="15"
                               FontFamily="Segoe UI"
                               Text="Run Autodesk Navisworks conversions on demand or schedule the app to process your DWG folder every two weeks." />
                </StackPanel>

                <StackPanel Grid.Column="1">
                    <Border Padding="16,10"
                            Background="{StaticResource AccentDimBrush}"
                            CornerRadius="16"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1">
                        <StackPanel>
                            <TextBlock Foreground="{StaticResource MutedTextBrush}" FontSize="12" Text="Task Scheduler Status" />
                            <TextBlock x:Name="SchedulerStatusText"
                                       Margin="0,4,0,0"
                                       FontSize="18"
                                       FontFamily="Bahnschrift SemiBold"
                                       Text="Checking..." />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="24,0,24,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Margin="0,0,18,0">
                <Border Margin="0,0,0,18"
                        Padding="22"
                        Background="{StaticResource PanelBrush}"
                        CornerRadius="22"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1">
                    <StackPanel>
                        <TextBlock FontSize="22" FontFamily="Bahnschrift SemiBold" Text="Conversion Setup" />
                        <TextBlock Margin="0,6,0,18"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   FontFamily="Segoe UI"
                                   Text="Choose your DWG source folder, where NWC files should be written, and which Navisworks task runner should execute the conversion." />

                        <TextBlock Margin="0,0,0,6" FontSize="13" Text="Folder A: DWG input" />
                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="InputFolderTextBox" />
                            <Button Grid.Column="1"
                                    Margin="10,0,0,0"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Content="Browse"
                                    Click="BrowseInputFolder_Click" />
                            <Button Grid.Column="2"
                                    Margin="10,0,0,0"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Content="Open"
                                    Click="OpenInputFolder_Click" />
                        </Grid>

                        <CheckBox x:Name="SameAsInputCheckBox"
                                  Margin="0,0,0,14"
                                  Content="Save NWC files into Folder A"
                                  Checked="SameAsInputCheckBox_Changed"
                                  Unchecked="SameAsInputCheckBox_Changed" />

                        <TextBlock Margin="0,0,0,6" FontSize="13" Text="Folder B: NWC output" />
                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="OutputFolderTextBox" />
                            <Button x:Name="BrowseOutputButton"
                                    Grid.Column="1"
                                    Margin="10,0,0,0"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Content="Browse"
                                    Click="BrowseOutputFolder_Click" />
                            <Button x:Name="OpenOutputButton"
                                    Grid.Column="2"
                                    Margin="10,0,0,0"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Content="Open"
                                    Click="OpenOutputFolder_Click" />
                        </Grid>

                        <TextBlock Margin="0,0,0,6" FontSize="13" Text="Navisworks FiletoolsTaskRunner.exe" />
                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="ToolPathTextBox" />
                            <Button Grid.Column="1"
                                    Margin="10,0,0,0"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Content="Browse"
                                    Click="BrowseToolPath_Click" />
                        </Grid>

                        <Grid Margin="0,4,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Margin="0,0,10,0">
                                <TextBlock Margin="0,0,0,6" FontSize="13" Text="Parallel conversions" />
                                <ComboBox x:Name="ParallelismComboBox" SelectedIndex="3">
                                    <ComboBoxItem Content="1" />
                                    <ComboBoxItem Content="2" />
                                    <ComboBoxItem Content="3" />
                                    <ComboBoxItem Content="4" />
                                    <ComboBoxItem Content="5" />
                                    <ComboBoxItem Content="6" />
                                    <ComboBoxItem Content="8" />
                                </ComboBox>
                            </StackPanel>

                            <Border Grid.Column="1"
                                    Padding="14"
                                    Background="{StaticResource PanelAltBrush}"
                                    CornerRadius="16"
                                    BorderBrush="{StaticResource BorderBrush}"
                                    BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Foreground="{StaticResource MutedTextBrush}" FontSize="12" Text="Latest Summary" />
                                    <TextBlock x:Name="SummaryTextBlock"
                                               Margin="0,6,0,0"
                                               TextWrapping="Wrap"
                                               FontFamily="Segoe UI"
                                               FontSize="14"
                                               Text="No batch has run yet." />
                                </StackPanel>
                            </Border>
                        </Grid>

                        <StackPanel Orientation="Horizontal" Margin="0,20,0,0">
                            <Button x:Name="RunNowButton"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Content="Run Conversion Now"
                                    Click="RunNowButton_Click" 
                                    BorderBrush="{StaticResource PanelBrush}"
                                    BorderThickness="2"/>
                            <Button Style="{StaticResource SecondaryButtonStyle}"
                                    Content="Save Settings"
                                    Click="SaveSettingsButton_Click" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Padding="22"
                        Background="{StaticResource PanelBrush}"
                        CornerRadius="22"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock FontSize="22" FontFamily="Bahnschrift SemiBold" Text="Activity Log" />
                            <Button Margin="16,0,0,0"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Content="Clear"
                                    Click="ClearLogButton_Click" />
                        </StackPanel>

                        <ListBox x:Name="LogListBox" Grid.Row="1" Margin="0,18,0,0" />
                    </Grid>
                </Border>
            </StackPanel>

            <Expander Grid.Column="1"
                      Margin="0,0,0,18"
                      VerticalAlignment="Top"
                      Style="{StaticResource AutomationPanelExpanderStyle}"
                      Header="Automation"
                      IsExpanded="false">
                <StackPanel>
                    <TextBlock Margin="0,0,0,18"
                               Foreground="{StaticResource MutedTextBrush}"
                               FontFamily="Segoe UI"
                               Text="Save the same conversion settings for a Windows scheduled task so the app can run itself every two weeks without opening the interface." />

                    <TextBlock Margin="0,0,0,6" FontSize="13" Text="Task name" />
                    <TextBox x:Name="TaskNameTextBox" Margin="0,0,0,14" />

                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Margin="0,0,10,0">
                            <TextBlock Margin="0,0,0,6" FontSize="13" Text="Repeat every 2 weeks on" />
                            <ComboBox x:Name="ScheduledDayComboBox">
                                <ComboBoxItem Content="MON" />
                                <ComboBoxItem Content="TUE" />
                                <ComboBoxItem Content="WED" />
                                <ComboBoxItem Content="THU" />
                                <ComboBoxItem Content="FRI" />
                                <ComboBoxItem Content="SAT" />
                                <ComboBoxItem Content="SUN" />
                            </ComboBox>
                        </StackPanel>

                        <StackPanel Grid.Column="1">
                            <TextBlock Margin="0,0,0,6" FontSize="13" Text="Start time (24h)" />
                            <TextBox x:Name="ScheduledTimeTextBox" Text="08:00" />
                        </StackPanel>
                    </Grid>

                    <Border Padding="14"
                            Background="{StaticResource PanelAltBrush}"
                            CornerRadius="16"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1">
                        <StackPanel>
                            <TextBlock Foreground="{StaticResource MutedTextBrush}" FontSize="12" Text="What gets scheduled" />
                            <TextBlock Margin="0,6,0,0"
                                       TextWrapping="Wrap"
                                       FontFamily="Segoe UI"
                                       FontSize="14"
                                       Text="The scheduled task launches this application with the saved settings using the --run-scheduled argument. That means the same tool path, folders, and parallelism are reused automatically." />
                        </StackPanel>
                    </Border>

                    <StackPanel Margin="0,18,0,18">
                        <Button Style="{StaticResource PrimaryButtonStyle}"
                                Content="Create or Update Schedule"
                                Click="CreateScheduleButton_Click" />
                        <Button Margin="0,10,0,0"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Content="Run Scheduled Task Now"
                                Click="RunScheduledTaskButton_Click" />
                        <Button Margin="0,10,0,0"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Content="Refresh Status"
                                Click="RefreshSchedulerButton_Click" />
                        <Button Margin="0,10,0,0"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Content="Delete Schedule"
                                Click="DeleteScheduleButton_Click" />
                    </StackPanel>

                    <Border Padding="22"
                            Background="{StaticResource PanelBrush}"
                            CornerRadius="22"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1">
                        <StackPanel>
                            <TextBlock FontSize="22" FontFamily="Bahnschrift SemiBold" Text="Notes" />
                            <TextBlock Margin="0,10,0,0"
                                       Foreground="{StaticResource MutedTextBrush}"
                                       FontFamily="Segoe UI"
                                       TextWrapping="Wrap"
                                       Text="Make sure Autodesk Navisworks Manage 2024 is installed and that FiletoolsTaskRunner.exe exists at the path you selected." />
                            <TextBlock Margin="0,10,0,0"
                                       Foreground="{StaticResource MutedTextBrush}"
                                       FontFamily="Segoe UI"
                                       TextWrapping="Wrap"
                                       Text="If Folder B does not exist yet, the application will create it when the conversion starts." />
                            <TextBlock Margin="0,10,0,0"
                                       Foreground="{StaticResource WarnBrush}"
                                       FontFamily="Segoe UI Semibold"
                                       TextWrapping="Wrap"
                                       Text="Windows Task Scheduler can prompt for permission depending on your account policies. If schedule creation fails, try launching this app as Administrator." />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Expander>
        </Grid>
    </Grid>
</Window>
